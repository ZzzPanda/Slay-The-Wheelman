; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[android]

display/canvas_resize_policy=2
display/safe_area_margin=0.0

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="SlayTheRobot"
run/main_scene="res://scenes/Root.tscn"
config/features=PackedStringArray("4.6")
config/icon="uid://8kopj5luv8dc"

[autoload]

Signals="*res://autoload/Signals.gd"
Scenes="*res://autoload/Scenes.gd"
Scripts="*res://autoload/Scripts.gd"
FileLoader="*res://autoload/FileLoader.gd"
Random="*res://autoload/Random.gd"
Global="*res://autoload/Global.gd"
ActionHandler="*res://autoload/ActionHandler.gd"
ActionGenerator="*res://autoload/ActionGenerator.gd"
DebugLogger="*res://autoload/DebugLogger.gd"
UIDGenerator="*res://autoload/UIDGenerator.gd"

[debug]

gdscript/warnings/unused_signal=0
gdscript/warnings/integer_division=0

[display]

window/size/viewport_width=1200
window/size/viewport_height=700
window/size/resizable=false
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="Slay The Robot"

